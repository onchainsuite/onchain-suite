{
  "name": "onchain-suite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "commit": "cz",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "bun run lint && bun run build",
    "validate": "bun run type-check && bun run lint && bun run prettier",
    "rename:kebab-files": "find . -name '*.ts' -o -name '*.tsx' | grep -v node_modules | grep -v .next | grep -v .git | while read file; do newname=$(echo \"$file\" | sed 's/\\([A-Z]\\)/-\\L\\1/g' | sed 's/^-//' | sed 's/\\/-/-/g'); [ \"$file\" != \"$newname\" ] && mv \"$file\" \"$newname\" 2>/dev/null || true; done",
    "rename:kebab-dirs": "find . -type d \\( -path './node_modules' -o -path './.next' -o -path './.git' \\) -prune -o -type d -print | grep -E '[A-Z]' | sort -r | while read dir; do newdir=$(echo \"$dir\" | sed 's|/\\([A-Z]\\)|/-\\L\\1|g' | sed 's|^-||' | sed 's|/-|/|g'); [ \"$dir\" != \"$newdir\" ] && mv \"$dir\" \"$newdir\" 2>/dev/null || true; done",
    "rename:kebab-all": "bun run rename:kebab-dirs && bun run rename:kebab-files",
    "imports:check": "eslint . --no-fix --rule 'no-restricted-imports: [error, { patterns: [{ group: [../*], message: Use absolute imports with @/ instead of relative parent imports (../) }] }]'",
    "imports:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css,scss,html}\"",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:e2e:google-oauth": "vitest run src/test/google-oauth.e2e.test.ts",
    "check-all": "bun run lint && bun run format",
    "email:dev": "bunx email dev --root src/shared/emails"
  },
  "dependencies": {
    "@arcjet/inspect": "^1.9.1",
    "@arcjet/next": "^1.9.1",
    "@azure/communication-email": "^1.1.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.3",
    "@hugeicons/react": "^1.1.9",
    "@kmenu/react": "^2.0.3",
    "@radix-ui/react-accordion": "^1.2.17",
    "@radix-ui/react-alert-dialog": "^1.1.20",
    "@radix-ui/react-avatar": "^1.2.3",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-collapsible": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-radio-group": "^1.4.4",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@react-oauth/google": "^0.13.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.45.0",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.7",
    "@tsparticles/engine": "^4.3.2",
    "@tsparticles/react": "^4.3.2",
    "@tsparticles/slim": "^4.3.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.11.2",
    "axios": "^1.18.1",
    "better-auth": "^1.6.23",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
